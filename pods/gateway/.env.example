TZ=America/Argentina/Buenos_Aires

# Pi-hole
PIHOLE_WEB_PORT=8085
# Hostnames desde los que se puede acceder a la UI de Pi-hole
# Ejemplo: '["myhostname", "myhostname.yourdomain.ts.net"]'
PIHOLE_TRUSTED_HOSTS=["your-hostname", "your-hostname.your-tailnet.ts.net"]

# El secret pi_password se maneja con `podman secret create pi_password -`
# No definir la contraseña aquí
