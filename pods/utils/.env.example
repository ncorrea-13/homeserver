TZ=America/Argentina/Buenos_Aires

# Homepage
HOMEPAGE_PORT=3000
# Ejemplo: 100.x.x.x:3000,your-hostname.your-tailnet.ts.net,localhost
HOMEPAGE_ALLOWED_HOSTS=your-tailscale-ip:3000,your-hostname.your-tailnet.ts.net,localhost

# Uptime Kuma
UPTIME_KUMA_PORT=3001
# Path al socket rootless de Podman para tu usuario
# Ejemplo: /run/user/1000/podman/podman.sock
PODMAN_SOCKET=/run/user/1000/podman/podman.sock

# Ntfy
NTFY_PORT=2586
NTFY_UID=1000
NTFY_GID=1000
# URL base pública de ntfy (la que usan los clientes para conectarse)
# Ejemplo: https://your-hostname.your-tailnet.ts.net:2586
NTFY_BASE_URL=https://your-hostname.your-tailnet.ts.net:2586
